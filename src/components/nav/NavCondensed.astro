---
import { items, isActive } from "./NavData";
const { currentPath = "/" } = Astro.props;

const primary = items.slice(0, 5);
const more = items.slice(5);
---
<div class="hidden w-full items-center justify-center md:flex lg:hidden">
  <ul class="navlist flex items-center">
    {primary.map((it) => (
      <li>
        <a href={it.href} class="navlink">
          {it.label}
          {isActive(currentPath, it.href) && <span class="navlink__active-underline" />}
        </a>
      </li>
    ))}

    <li class="relative">
      <details class="group">
        <summary class="navlink list-none cursor-pointer select-none">
          More <span aria-hidden="true">▴</span>
        </summary>

        <div class="absolute left-1/2 z-20 mt-3 w-56 -translate-x-1/2 rounded-sm bg-white shadow-lg ring-1 ring-black/5">
          <ul class="py-2">
            {more.map((it) => (
              <li>
                <a href={it.href} class="navlink block px-5 py-3 no-underline">
                  {it.label}
                  {isActive(currentPath, it.href) && <span class="navlink__active-underline" />}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </li>
  </ul>
</div>
