---
const { url } = Astro.props;

if (!url) throw new Error("InstaEmbed requires url");

const iframeId = `iframe-${Math.random().toString(36).slice(2)}`;

// GoDaddy uses embed.js + postMessage resizing.
// We keep this payload unescaped here; Astro will escape appropriately for srcdoc.
const srcdoc = `
<script>
  window.onmessage = function(event) {
    event.source.postMessage(
      {
        iframeId: event.data,
        scrollHeight: document.body.getBoundingClientRect().height || document.body.scrollHeight
      },
      event.origin
    );
  };
</script>
<body style='margin: 0;'>
  <div style="display: flex; justify-content: center">
    <blockquote
      class="instagram-media"
      data-instgrm-captioned
      data-instgrm-permalink="${url}"
      data-instgrm-version="14"
      style=" background:#FFF; border:0; border-radius:3px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 1px; max-width:540px; min-width:326px; padding:0; width:99.375%; width:-webkit-calc(100% - 2px); width:calc(100% - 2px);"
    ></blockquote>
    <script async src="//www.instagram.com/embed.js"></script>
  </div>
</body>
`;
---

<iframe
  id={iframeId}
  class="insta-iframe"
  frameborder="0"
  sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-presentation allow-top-navigation"
  src="javascript: window.frameElement.getAttribute('srcdoc');"
  srcdoc={srcdoc}
  loading="lazy"
  style="width:100%;height:0px;overflow:visible;transition:height 1.5s ease;-webkit-transition:height 1.5s ease;-moz-transition:height .25s ease"
/>

<script define:vars={{ iframeId }}>
  const iframe = document.getElementById(iframeId);
  if (!iframe) return;

  function requestSize() {
    try {
      iframe.contentWindow?.postMessage(iframeId, "*");
    } catch {}
  }

  function onMessage(event) {
    const d = event.data;
    if (!d || d.iframeId !== iframeId) return;
    const h = Number(d.scrollHeight);
    if (!Number.isFinite(h) || h <= 0) return;
    iframe.style.height = `${Math.ceil(h)}px`;
  }

  window.addEventListener("message", onMessage);

  // Kick a few times (embed.js loads async and height changes)
  requestSize();
  const t = window.setInterval(requestSize, 500);
  window.setTimeout(() => window.clearInterval(t), 8000);

  window.addEventListener("resize", requestSize);
</script>
