#!/usr/bin/env bash
set -euo pipefail

PIDFILE=".devserver.pid"
LOGFILE=".devserver.log"

is_running() {
  [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

start() {
  if is_running; then
    echo "dev: already running (pid $(cat "$PIDFILE"))"
    exit 0
  fi
  : > "$LOGFILE"
  (npm run dev >>"$LOGFILE" 2>&1) &
  echo $! > "$PIDFILE"
  echo "dev: started (pid $!)"
  echo "dev: log -> $LOGFILE"
}

stop() {
  if ! is_running; then
    echo "dev: not running"
    rm -f "$PIDFILE"
    exit 0
  fi
  kill "$(cat "$PIDFILE")" || true
  rm -f "$PIDFILE"
  echo "dev: stopped"
}

restart() { stop; start; }

clean() {
  rm -rf .astro node_modules/.vite
  echo "dev: cleared .astro and node_modules/.vite"
}

log() {
  touch "$LOGFILE"
  tail -n 200 -f "$LOGFILE"
}

case "${1:-}" in
  start) start ;;
  stop) stop ;;
  restart) restart ;;
  clean) clean ;;
  clean-restart) clean; restart ;;
  log) log ;;
  *) echo "usage: $0 {start|stop|restart|clean|clean-restart|log}"; exit 2 ;;
esac
