	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"routes": [
		{
			"pattern": "surviveandthrivesupportgroup.com",
			"custom_domain": true
		},
		{
			"pattern": "www.surviveandthrivesupportgroup.com",
			"custom_domain": true
		},
		{
			"pattern": "surviveandthrivesupportgroup.co.uk",
			"custom_domain": true
		},
		{
			"pattern": "www.surviveandthrivesupportgroup.co.uk",
			"custom_domain": true
		},
		{
			"pattern": "surviveandthrivesupportgroup.org",
			"custom_domain": true
		},
		{
			"pattern": "www.surviveandthrivesupportgroup.org",
			"custom_domain": true
		}
	],
	"send_email": [
		{
			"name": "EMAIL",
