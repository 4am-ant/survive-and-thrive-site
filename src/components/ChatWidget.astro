---
// Floating chat / quick-contact widget — appears bottom-right on all pages.
// Submits to the same /api/contact endpoint as the main contact form.
const TURNSTILE_SITE_KEY = "0x4AAAAAACoB9MOG7IqLPQ6L";
---

<!-- Toggle button -->
<button
  id="chat-btn"
  class="chat-btn"
  aria-label="Send us a message"
  aria-expanded="false"
  aria-controls="chat-panel"
>
  <!-- Speech bubble icon — exactly as requested (tail moved left) -->
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="chat-btn__icon">
    <path d="M22 3H2c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h3v5l9-4h8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/>
  </svg>
  <!-- X icon (shown when open) -->
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="chat-btn__close">
    <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
  </svg>
</button>

<!-- Panel -->
<div id="chat-panel" class="chat-panel" role="dialog" aria-label="Send us a message" aria-modal="true" hidden>
  <div class="chat-panel__header">
    <span class="chat-panel__title">Send us a message</span>
  </div>

  <form id="chat-form" class="chat-form" novalidate data-source="chat">
    <div class="form-field-float">
      <input id="chat-name" name="name" type="text" class="form-input-float" autocomplete="name" placeholder=" " />
      <label for="chat-name" class="form-label-float">Name</label>
    </div>

    <div class="form-field-float">
      <input id="chat-email" name="email" type="email" class="form-input-float" required autocomplete="email" placeholder=" " />
      <label for="chat-email" class="form-label-float">Email *</label>
      <div id="chat-email-error" class="form-error-inline" aria-live="polite"></div>
    </div>

    <div class="form-field">
      <label for="chat-message" class="form-label">Message</label>
      <textarea id="chat-message" name="message" class="form-textarea" rows="4"
        placeholder="How can we help?"></textarea>
    </div>

    <input type="hidden" name="source" value="chat" />

    <!-- Turnstile widget (compact size) -->
    <div
      class="cf-turnstile"
      data-sitekey={TURNSTILE_SITE_KEY}
      data-theme="light"
      data-size="compact"
    ></div>

    <div class="my-3 text-center text-xs text-gray-600">
      By sending this form you agree to our <a href="/privacy-policy" class="underline">Privacy Policy</a>.
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary chat-submit">Send</button>
    </div>

    <div id="chat-status" class="form-status" aria-live="polite"></div>

    <!-- Submitting / success overlay -->
    <div id="chat-overlay" class="form-overlay" hidden>
      <p id="chat-overlay-msg" class="form-overlay__msg">Sending…</p>
    </div>
  </form>
</div>

<script>
  const btn      = document.getElementById("chat-btn")        as HTMLButtonElement | null;
  const panel    = document.getElementById("chat-panel")      as HTMLElement | null;
  const form     = document.getElementById("chat-form")       as HTMLFormElement | null;
  const statusEl = document.getElementById("chat-status")     as HTMLElement | null;
  const emailInput = document.getElementById("chat-email")    as HTMLInputElement | null;
  const emailError = document.getElementById("chat-email-error") as HTMLElement | null;
  const overlay    = document.getElementById("chat-overlay")  as HTMLElement | null;
  const overlayMsg = document.getElementById("chat-overlay-msg") as HTMLElement | null;

  function openPanel() {
    if (!panel || !btn) return;
    panel.hidden = false;
    btn.setAttribute("aria-expanded", "true");
    btn.classList.add("chat-btn--open");
    panel.querySelector<HTMLInputElement>("#chat-name")?.focus();
  }

  function closePanel() {
    if (!panel || !btn) return;
    panel.hidden = true;
    btn.setAttribute("aria-expanded", "false");
    btn.classList.remove("chat-btn--open");
  }

  btn?.addEventListener("click", () => {
    panel?.hidden ? openPanel() : closePanel();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !panel?.hidden) closePanel();
  });

  const validateEmail = () => {
    if (!emailInput || !emailError) return false;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const value = emailInput.value.trim();
    if (value === "") {
      emailError.textContent = "Email address is required.";
      return false;
    }
    if (!emailRegex.test(value)) {
      emailError.textContent = "Please enter a valid email address.";
      return false;
    }
    emailError.textContent = "";
    return true;
  };

  emailInput?.addEventListener("blur", validateEmail);

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !statusEl || !emailInput) return;

    const isEmailValid = validateEmail();
    if (!isEmailValid) {
      emailInput.focus();
      return;
    }

    const submitBtn = form.querySelector<HTMLButtonElement>(".chat-submit");
    if (submitBtn) submitBtn.disabled = true;
    statusEl.textContent = "";
    statusEl.className = "form-status";

    if (overlay && overlayMsg) {
      overlayMsg.textContent = "Sending…";
      overlayMsg.className = "form-overlay__msg";
      overlay.hidden = false;
    }

    try {
      const res  = await fetch("/api/contact", { method: "POST", body: new FormData(form) });
      const data = (await res.json()) as { success: boolean; error?: string };

      if (data.success) {
        if (overlayMsg) {
          overlayMsg.textContent = "Message sent — we'll be in touch soon!";
          overlayMsg.className = "form-overlay__msg form-overlay__msg--ok";
        }
        form.reset();
        if (typeof (window as any).turnstile !== "undefined") {
          (window as any).turnstile.reset();
        }
      } else {
        if (overlay) overlay.hidden = true;
        statusEl.textContent = data.error ?? "Something went wrong. Please try again.";
        statusEl.classList.add("form-status--err");
      }
    } catch {
      if (overlay) overlay.hidden = true;
      statusEl.textContent = "Could not send. Please check your connection.";
      statusEl.classList.add("form-status--err");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
