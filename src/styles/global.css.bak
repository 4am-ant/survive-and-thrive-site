@import url("https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Muli:wght@300;400;600;700&display=swap");

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --brand: #8702a9;
  --brand-hover: rgb(173, 3, 216);
  --panel: #f8f0ff;
  --bg: #ffffff;
  --text: #111111;
}

html,
body {
  background: var(--bg);
  color: var(--text);
}

body {
  font-family: "Muli", ui-sans-serif, system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

a {
  color: inherit;
}

.container-pad {
  padding-left: 1.25rem;
  padding-right: 1.25rem;
}
@media (min-width: 640px) {
  .container-pad {
    padding-left: 2rem;
    padding-right: 2rem;
  }
}