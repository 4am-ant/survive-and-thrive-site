---
import MainLayout from "../layouts/MainLayout.astro";
const TURNSTILE_SITE_KEY = "0x4AAAAAACoB9MOG7IqLPQ6L";
---

<MainLayout
  title="Contact Us – Survive and Thrive"
  description="Get in touch with the Survive and Thrive support group."
>
  <section class="page-section container-pad">
    <div class="content-max">
    <h1>Contact Us</h1>
    <h2>Drop us a line!</h2>

    <div class="contact-layout">
      <!-- Contact form -->
      <div class="contact-form-wrap">
        <form
          id="contact-form"
          class="contact-form"
          novalidate
          data-source="contact-form"
        >
          <div class="form-field-float">
            <input
              id="cf-name"
              name="name"
              type="text"
              class="form-input-float"
              autocomplete="name"
              placeholder=" "
            />
            <label for="cf-name" class="form-label-float">Name</label>
          </div>

          <div class="form-field-float">
            <input
              id="cf-email"
              name="email"
              type="email"
              class="form-input-float"
              required
              autocomplete="email"
              placeholder=" "
            />
            <label for="cf-email" class="form-label-float">
              Email *
            </label>
            <div id="cf-email-error" class="form-error-inline" aria-live="polite"></div>
          </div>

          <div class="form-field-float">
            <input
              id="cf-phone"
              name="phone"
              type="tel"
              class="form-input-float"
              autocomplete="tel"
              placeholder=" "
            />
            <label for="cf-phone" class="form-label-float">Phone</label>
          </div>

          <div class="form-field">
            <label for="cf-message" class="form-label">Message</label>
            <textarea
              id="cf-message"
              name="message"
              class="form-textarea"
              rows="6"
              placeholder="Please type your message to us here. We will get back to you as soon as we can."
            ></textarea>
          </div>

          <div class="form-field">
            <label for="cf-notes" class="form-label">Other notes</label>
            <textarea
              id="cf-notes"
              name="notes"
              class="form-textarea"
              rows="6"
              placeholder="Other notes"
            ></textarea>
          </div>

          <input type="hidden" name="source" value="contact-form" />

          <!-- Cloudflare Turnstile widget (Managed mode) -->
          <div
            class="cf-turnstile"
            data-sitekey={TURNSTILE_SITE_KEY}
            data-theme="light"
          ></div>

          <div class="my-4 text-center text-sm">
            By sending this form you agree to our <a href="/privacy-policy" class="underline">Privacy Policy</a>.
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-primary form-submit">Send</button>
          </div>

          <div id="cf-status" class="form-status" aria-live="polite"></div>
        </form>
      </div>

      <!-- Phone option -->
      <div class="contact-phone">
        <h2>Or give us a call!</h2>
        <p>
          There's much to see here. So, take your time, look around, and learn all there is to know about us. 
          We hope you enjoy our site and take a moment to drop us a line.<br />
          If you need to call us either press the button below or dial 07517122474.
        </p>
        <a href="tel:07517122474" class="btn-primary">Call Us</a>
      </div>

    </div>
    </div><!-- /.content-max -->
  </section>
</MainLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("cf-status") as HTMLElement | null;
  const emailInput = document.getElementById("cf-email") as HTMLInputElement | null;
  const emailError = document.getElementById("cf-email-error") as HTMLElement | null;

  const validateEmail = () => {
    if (!emailInput || !emailError) return false;
    
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const value = emailInput.value.trim();
    
    if (value === "") {
      emailError.textContent = "Email address is required.";
      return false;
    }
    
    if (!emailRegex.test(value)) {
      emailError.textContent = "Please enter a valid email address.";
      return false;
    }
    
    emailError.textContent = "";
    return true;
  };

  emailInput?.addEventListener("blur", validateEmail);

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !status || !emailInput) return;

    // Reset status and trigger validation
    status.textContent = "";
    status.className = "form-status";
    
    const isEmailValid = validateEmail();
    if (!isEmailValid) {
      emailInput.focus();
      return;
    }

    const submitBtn = form.querySelector<HTMLButtonElement>(".form-submit");
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        body: new FormData(form),
      });
      const data = (await res.json()) as { success: boolean; error?: string };

      if (data.success) {
        status.textContent = "Thank you — your message has been sent. We will get back to you as soon as we can.";
        status.classList.add("form-status--ok");
        form.reset();
        // Reset Turnstile widget
        if (typeof (window as any).turnstile !== "undefined") {
          (window as any).turnstile.reset();
        }
      } else {
        status.textContent = data.error ?? "Something went wrong. Please try again.";
        status.classList.add("form-status--err");
      }
    } catch {
      status.textContent = "Could not send message. Please check your connection and try again.";
      status.classList.add("form-status--err");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
