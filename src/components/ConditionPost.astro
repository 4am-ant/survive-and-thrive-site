---
import { conditions, CONDITIONS_BASE, BASE_URL } from "../data/conditions";
import ButterflyHeading from "./ButterflyHeading.astro";

interface Props {
  slug:        string;
  title:       string;
}

const { slug, title } = Astro.props;
const others   = conditions.filter(c => c.slug !== slug);
const pageUrl  = `${BASE_URL}${CONDITIONS_BASE}/${slug}`;
const shareUrl = encodeURIComponent(pageUrl);
const shareText = encodeURIComponent(title);
---

<div class="cond-post-layout">

  <div class="cond-post-body">
    <h2>{title}</h2>
    <slot />
  </div>

  <aside class="cond-post-sidebar">
    <h2>Other Conditions</h2>
    <ul>
      {others.map(c => (
        <li>
          <a class="cond-sidebar-condition" href={`${CONDITIONS_BASE}/${c.slug}`}>
            <ButterflyHeading tag="span">{c.title}</ButterflyHeading>
          </a>
        </li>
      ))}
    </ul>
  </aside>

  <div class="cond-post-share">
    <p class="cond-post-share__label">Share this post</p>
    <div class="cond-post-share__icons">
      <a href={`https://www.facebook.com/sharer.php?u=${shareUrl}`}
         target="_blank" rel="noopener noreferrer"
         aria-label="Share on Facebook" class="cond-share-btn">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      <button class="cond-share-btn" aria-label="Share via Instagram" data-share-native>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/></svg>
      </button>
      <a href={`https://x.com/intent/tweet?url=${shareUrl}&text=${shareText}`}
         target="_blank" rel="noopener noreferrer"
         aria-label="Share on X" class="cond-share-btn">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L2 2.25h6.985l4.265 5.636zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href={`https://api.whatsapp.com/send?text=${shareText}%20${shareUrl}`}
         target="_blank" rel="noopener noreferrer"
         aria-label="Share on WhatsApp" class="cond-share-btn">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      </a>
      <button class="cond-share-btn" aria-label="Copy link" data-copy-link={pageUrl}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>
  </div>

  <div class="cond-post-support">
    <p>For more support and more information on these conditions, please visit our resources page.</p>
    <a href="/resources" class="btn-primary">View Resources</a>
  </div>

</div>

<script is:inline>
(function () {
  document.querySelectorAll('[data-copy-link]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      navigator.clipboard.writeText(btn.dataset.copyLink).then(function () {
        btn.classList.add('cond-share-btn--copied');
        setTimeout(function () { btn.classList.remove('cond-share-btn--copied'); }, 2000);
      });
    });
  });
  document.querySelectorAll('[data-share-native]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (navigator.share) {
        navigator.share({ url: window.location.href, title: document.title });
      } else {
        navigator.clipboard.writeText(window.location.href);
      }
    });
  });
})();
</script>
